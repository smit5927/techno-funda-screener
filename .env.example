PORT=3000
DATA_DIR=/var/data
DEFAULT_WATCHLIST_PATH=config/universe.csv
CUSTOM_WATCHLIST_PATH=config/custom-list.csv
BENCHMARK_SYMBOL=^CRSLDX

SCHEDULE_ENABLED=true
SCAN_CRON=15 8 * * 1-5
SCAN_TIMEZONE=Asia/Kolkata
SCAN_CONCURRENCY=6
MAX_SYMBOLS=0

FUNDAMENTALS_ENABLED=true
FUNDAMENTALS_CACHE_DAYS=7

TELEGRAM_BOT_TOKEN=123456789:your_bot_token
TELEGRAM_CHAT_ID=123456789
TELEGRAM_SEND_EMPTY=false

TRADE_CAPITAL_PER_STOCK=100000
TRADE_DEFAULT_QTY=1
TRADE_ONLY_NEW_SIGNALS=true
