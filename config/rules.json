{
  "benchmark": "^CRSLDX",
  "benchmarkLabel": "NIFTY 500 / CNX500",
  "rsi": {
    "length": 14,
    "source": "close",
    "threshold": 50,
    "waitForTimeframeClose": true
  },
  "relativeStrength": {
    "source": "close",
    "formula": "(stockClose / stockCloseN) / (benchmarkClose / benchmarkCloseN) - 1",
    "weekly": {
      "period": 21,
      "trendRange": 5,
      "priceConfirmationPeriod": 61
    },
    "dailyLong": {
      "period": 55,
      "trendRange": 5,
      "priceConfirmationPeriod": 50
    },
    "dailyShort": {
      "period": 21,
      "trendRange": 5,
      "priceConfirmationPeriod": 50
    }
  },
  "supertrend": {
    "daily": {
      "atrLength": 10,
      "multiplier": 3
    }
  },
  "entry": {
    "weeklyRsiAbove": 50,
    "dailyRsiAbove": 50,
    "weeklyRsAbove": 0,
    "dailyLongRsAbove": 0,
    "dailyShortRsAbove": 0,
    "dailyPriceAboveSupertrend": true
  },
  "exit": {
    "weeklyRsBelow": 0,
    "logic": "weekly_rs_below_zero_on_closed_candle"
  },
  "setupStrength": {
    "compulsory": false,
    "dailyRecentHighPeriod": 55,
    "baseBreakoutPeriod": 20,
    "dailyYearHighPeriod": 252,
    "nearYearHighPct": 15,
    "volumeAveragePeriod": 50,
    "volumeExpansionMultiple": 1.5,
    "riskToSupertrendMaxPct": 7,
    "rsTrendLookback": 5,
    "smaFastPeriod": 50,
    "smaSlowPeriod": 200,
    "atrPeriod": 14,
    "maxAtrPct": 8,
    "minimumAverageTurnover": 10000000,
    "candleConfirmation": true,
    "marketRegime": true,
    "sectorBreadthMinPct": 50,
    "sectorBreadthMinStocks": 5,
    "retracementLookback": 5,
    "retracementMinPullbackPct": 2,
    "retracementMaxPullbackPct": 15,
    "retracementSupportProximityPct": 5,
    "retracementBreakoutRetestPct": 3,
    "retracementDryVolumeMaxRatio": 0.9,
    "retracementReclaimVolumeMinRatio": 1.1,
    "retracementMaxRiskPct": 8,
    "pyramidSwingLookback": 160,
    "pyramidPivotBars": 2,
    "pyramidMaximumPoints": 24,
    "fibonacciLookback": 55,
    "fibonacciProximityPct": 2,
    "bollingerPeriod": 20,
    "bollingerStdDev": 2,
    "rangeBoundMaxBandwidthPct": 10
  },
  "gtfConfluence": {
    "compulsory": false,
    "baseBodyLimit": 0.495,
    "significantGapPct": 1,
    "maxBaseCandles": 3,
    "entryBufferPct": 0.1,
    "stopBufferPct": 0.4,
    "maxSupportDistancePct": 8,
    "supplyBlockDistancePct": 3,
    "dirtyBaseWickRatio": 1.2
  },
  "institutionalContext": {
    "enabled": true,
    "indexSymbols": [
      { "id": "nifty500", "label": "NIFTY 500", "symbol": "^CRSLDX", "primary": true },
      { "id": "nifty50", "label": "NIFTY 50", "symbol": "^NSEI" },
      { "id": "banknifty", "label": "BANK NIFTY", "symbol": "^NSEBANK" }
    ],
    "commoditySymbols": [
      { "id": "gold", "label": "Gold", "symbol": "GC=F", "group": "precious_metals" },
      { "id": "silver", "label": "Silver", "symbol": "SI=F", "group": "precious_metals" },
      { "id": "copper", "label": "Copper", "symbol": "HG=F", "group": "base_metals" },
      { "id": "crude", "label": "Crude Oil", "symbol": "CL=F", "group": "energy" },
      { "id": "usdinr", "label": "USD/INR", "symbol": "INR=X", "group": "currency" }
    ],
    "optionChainEnabled": true,
    "deliveryEnabled": true,
    "deliveryExpansionMultiple": 1.2,
    "optionChainSymbols": ["NIFTY", "BANKNIFTY"],
    "fnoLotSizeUrl": "https://nsearchives.nseindia.com/content/fo/fo_mktlots.csv",
    "oiSpurtsUrl": "https://www.nseindia.com/api/live-analysis-oi-spurts-underlyings"
  },
  "fundamentals": {
    "compulsory": false,
    "checks": [
      "netIncomeYoYUp",
      "operatingIncomeYoYUp",
      "revenueQuarterYoYUp",
      "epsQuarterYoYUp",
      "ebitdaQuarterYoYUp",
      "ebitdaMarginQoQUp",
      "ebitdaMarginYoYUp",
      "peRising"
    ]
  }
}
